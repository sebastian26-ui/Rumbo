# Critical: never copy node_modules from the host — it contains
# better-sqlite3 native binaries built for the host OS (macOS) that
# overwrite the Linux build produced by `npm ci` inside the image,
# producing `invalid ELF header` at runtime.
node_modules

# Vite output is regenerated by `npm run build` in the image.
dist

# Large GTFS feed + SQLite cache live on the Fly volume, not in the image.
data

# Local-only
.git
.gitignore
.env
.env.*
*.log
.DS_Store
