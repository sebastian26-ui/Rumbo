# --- Walk / bike / drive routing -------------------------------------------
# Routing engine selection. Default: graphhopper.
ROUTING_PROVIDER=graphhopper

# GraphHopper Directions API key. Required when ROUTING_PROVIDER=graphhopper.
# Sign up at https://www.graphhopper.com/ — free tier is 500 req/day.
GRAPHHOPPER_API_KEY=

# Self-hosted OSRM base URL. Required when ROUTING_PROVIDER=osrm.
# DO NOT point at https://router.project-osrm.org — that public demo only
# runs the car profile and silently returns car routes for foot/bike.
# OSRM_BASE_URL=https://your-osrm.example.com


# --- Transit routing (Metro + micro + Metrotren) ---------------------------
# Transit engine. Default: gtfs (Santiago's official DTPM feed, parsed once
# into SQLite). Set to `google` to fall back to Google Directions transit.
TRANSIT_PROVIDER=gtfs

# GTFS pipeline. Run `npm run gtfs:ingest` to download the DTPM feed and
# build the SQLite cache. The script tries, in order:
#   1. GTFS_ZIP_PATH  — local pre-downloaded zip
#   2. GTFS_ZIP_URL   — direct URL to the zip
#   3. Scrape https://www.dtpm.cl/index.php/noticias/gtfs-vigente
# Override the DB destination if you want to keep multiple feeds around.
# GTFS_ZIP_PATH=/absolute/path/to/gtfs.zip
# GTFS_ZIP_URL=
# GTFS_DB_PATH=./data/gtfs.db

# Google Maps API key — used only when TRANSIT_PROVIDER=google.
# 1. Create a project in Google Cloud Console.
# 2. Enable the "Directions API" for that project.
# 3. Create an API key. RESTRICT IT to:
#    - API: Directions API only
#    - HTTP referrers / IPs: your dev + deployment domains
# 4. Paste the key below.
GOOGLE_MAPS_API_KEY=


# --- Geocoding -------------------------------------------------------------
# NOMINATIM_BASE_URL=https://nominatim.openstreetmap.org
# GEOCODING_USER_AGENT=YourApp/1.0 (contact: you@example.com)


# --- Provider price comparison ---------------------------------------------
# Ride-hailing / scooter / shared-bike estimates are computed CLIENT-SIDE
# from public Santiago tariffs in src/lib/fares.ts (no API keys needed and
# no third-party developer accounts required). Edit fares.ts to spot-check
# tariffs before launch.


# --- Server ----------------------------------------------------------------
# PORT=4000

# CORS allowlist (comma-separated). Origins that may call /api/*. In dev
# requests come same-origin via Vite middleware so this is effectively
# unused; set to your public domain(s) in production.
CORS_ALLOWED_ORIGINS=https://rumbo.cl,https://www.rumbo.cl


# --- Transactional email (verification + future password reset) -----------
# Resend API key. Required for verification emails. Sign up at https://resend.com,
# verify rumbo.cl in Domains, and paste the API key here.
RESEND_API_KEY=

# From + Reply-To for transactional mail. The From must use a domain that's
# verified in Resend (DKIM/SPF live in DNS). Reply-To can be any address you
# actually monitor — replies to no-reply@ bounce into the void.
RESEND_FROM=Rumbo <no-reply@rumbo.cl>
RESEND_REPLY_TO=support@rumbo.cl

# Firebase Admin service account JSON, pasted as a single-line string.
# Download from Firebase Console -> Project settings -> Service accounts
# -> "Generate new private key". The private_key field embeds \n escapes;
# they're restored to real newlines at load time.
FIREBASE_SERVICE_ACCOUNT=

# Where the verification link sends users after Firebase applies the code.
# Used as actionCodeSettings.url on the server-generated link.
APP_PUBLIC_URL=https://rumbo.cl


# --- Observability ---------------------------------------------------------
# Sentry server DSN (used by server.ts and the GTFS cron). Leave empty in
# local dev — Sentry init is a no-op when DSN is unset.
SENTRY_DSN=


# --- Client-bundled (VITE_*) -----------------------------------------------
# Everything below this line is exposed to the browser bundle by Vite.
# DO NOT put server-side secrets here.

# Sentry browser DSN. Leave empty in local dev.
VITE_SENTRY_DSN=

# Firebase App Check via reCAPTCHA Enterprise. Create the key in Google
# Cloud Console -> Security -> reCAPTCHA Enterprise, then register the
# site key in Firebase Console -> App Check -> Apps -> Web App. Leave
# empty in local dev to skip App Check init.
VITE_RECAPTCHA_SITE_KEY=
